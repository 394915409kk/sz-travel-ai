APP_ENV=development
# Local default when unset: apps/backend/travel_products.db
# Docker internal-beta default: /data/travel_products.db
SQLITE_DB_PATH=/data/travel_products.db
SQLITE_BACKUP_DIR=/app/backups
# Optional future database URL. Do not store real production credentials here.
# DATABASE_URL=
AUTO_INIT_DB_ON_STARTUP=true
INTERNAL_API_KEY=change-me-internal-beta-key
PORT=8000
